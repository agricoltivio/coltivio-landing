---
import Base from '@/layouts/Base.astro'
import DataDeletionPage from '@/components/DataDeletionPage.astro'
import { getTranslations } from '@/i18n/translations'

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'it' } },
    { params: { lang: 'en' } },
  ]
}

const { lang } = Astro.params
const tr = getTranslations(lang)
---

<Base lang={lang} title={`${tr.dataDeletion.title} — Coltivio`} description={tr.dataDeletion.title}>
  <DataDeletionPage tr={tr} lang={lang} />
</Base>
